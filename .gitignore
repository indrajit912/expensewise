# pyenv
#   For a library or app, you might want to share your .python-version.
#   See https://github.com/pyenv/pyenv/blob/master/COMMANDS.md#pyenv-version-file
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if development environment differs from production,
#   Pipfile.lock might be shared or not.
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally recommended to be committed
#Poetry.lock

# pdm
#   Similar to Pipenv, pdm.lock is generally recommended to be committed
#pdm.lock
.pdm-plugins/

